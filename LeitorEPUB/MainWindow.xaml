<Window x:Class="LeitorEPUB.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Leitor EPUB com Voz IA"
        Height="700" Width="1000"
        MinHeight="400" MinWidth="600"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="{DynamicResource MenuBackgroundBrush}" Foreground="{DynamicResource ForegroundBrush}">
            <MenuItem x:Name="MenuFile" Header="Arquivo">
                <MenuItem x:Name="MenuOpen" Header="Abrir EPUB" Click="OpenEpub_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuDelete" Header="Apagar Dados" Click="DeleteData_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuExit" Header="Sair" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem x:Name="MenuSettings" Header="Configuracoes">
                <MenuItem x:Name="MenuLanguage" Header="Idioma">
                    <MenuItem x:Name="Lang_pt" Header="Português" Tag="pt" Click="Language_Click"/>
                    <MenuItem x:Name="Lang_en" Header="English" Tag="en" Click="Language_Click"/>
                    <MenuItem x:Name="Lang_es" Header="Español" Tag="es" Click="Language_Click"/>
                    <MenuItem x:Name="Lang_fr" Header="Français" Tag="fr" Click="Language_Click"/>
                    <MenuItem x:Name="Lang_de" Header="Deutsch" Tag="de" Click="Language_Click"/>
                    <MenuItem x:Name="Lang_it" Header="Italiano" Tag="it" Click="Language_Click"/>
                    <MenuItem x:Name="Lang_ar" Header="العربية" Tag="ar" Click="Language_Click"/>
                    <MenuItem x:Name="Lang_hi" Header="हिन्दी" Tag="hi" Click="Language_Click"/>
                    <MenuItem x:Name="Lang_zh" Header="中文" Tag="zh" Click="Language_Click"/>
                    <MenuItem x:Name="Lang_jp" Header="日本語" Tag="jp" Click="Language_Click"/>
                    <MenuItem x:Name="Lang_ko" Header="한국어" Tag="ko" Click="Language_Click"/>
                    <MenuItem x:Name="Lang_ru" Header="Русский" Tag="ru" Click="Language_Click"/>
                </MenuItem>
                <MenuItem x:Name="MenuVoice" Header="Voz"/>
                <MenuItem x:Name="MenuTheme" Header="Tema">
                    <MenuItem x:Name="ThemeLight" Header="Claro" Click="Theme_Click" Tag="light"/>
                    <MenuItem x:Name="ThemeDark" Header="Escuro" Click="Theme_Click" Tag="dark"/>
                    <MenuItem x:Name="ThemeSystem" Header="Sistema" Click="Theme_Click" Tag="system"/>
                </MenuItem>
            </MenuItem>
            <MenuItem x:Name="MenuAbout" Header="Sobre" Click="About_Click"/>
        </Menu>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="8,5" Background="{DynamicResource PanelBrush}">
                    <Grid>
                        <TextBlock x:Name="BookTitle" Text="" FontSize="13" FontStyle="Italic"
                                   Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                        <Button x:Name="TocButton" Content="T" Width="32" Height="32"
                                HorizontalAlignment="Right" Style="{StaticResource ControlButton}"
                                Click="TocToggle_Click"/>
                    </Grid>
                </Border>
                <RichTextBox Grid.Row="1" x:Name="TextArea" IsReadOnly="True"
                             BorderThickness="0" Margin="15,10" Padding="10,5"
                             Background="{DynamicResource TextBackgroundBrush}"
                             Foreground="{DynamicResource ForegroundBrush}"
                             FontSize="15" VerticalScrollBarVisibility="Auto"/>
                <Border Grid.Row="2" Padding="12,8" Background="{DynamicResource PanelBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Name="StatusText" Text="Pronto" FontSize="13"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button x:Name="PrevButton" Content="Anterior" MinWidth="50" Height="38" 
                                        Padding="10,6" Style="{StaticResource ControlButton}" Click="PrevButton_Click"/>
                                <Button x:Name="PlayButton" Content="Play" MinWidth="90" Height="38" Margin="8,0" 
                                        Padding="10,6" Style="{StaticResource ControlButton}" Click="PlayButton_Click"/>
                                <Button x:Name="NextButton" Content="Próximo" MinWidth="50" Height="38" 
                                        Padding="10,6" Style="{StaticResource ControlButton}" Click="NextButton_Click"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="30,0,10,0">
                            <TextBlock x:Name="SpeedLabel" Text="Velocidade:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                            <ComboBox x:Name="SpeedSelector" Width="80" Height="30"
                                      Background="{DynamicResource ChoiceBrush}"
                                      Foreground="{DynamicResource ForegroundBrush}"
                                      SelectionChanged="SpeedSelector_SelectionChanged">
                                <ComboBoxItem>0.25x</ComboBoxItem>
                                <ComboBoxItem>0.50x</ComboBoxItem>
                                <ComboBoxItem>0.75x</ComboBoxItem>
                                <ComboBoxItem IsSelected="True">1.00x</ComboBoxItem>
                                <ComboBoxItem>1.25x</ComboBoxItem>
                                <ComboBoxItem>1.50x</ComboBoxItem>
                                <ComboBoxItem>1.75x</ComboBoxItem>
                                <ComboBoxItem>2.00x</ComboBoxItem>
                                <ComboBoxItem>2.25x</ComboBoxItem>
                                <ComboBoxItem>2.50x</ComboBoxItem>
                                <ComboBoxItem>2.75x</ComboBoxItem>
                                <ComboBoxItem>3.00x</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
            <Border Grid.Column="1" x:Name="ChapterPanel" Width="280"
                    Background="{DynamicResource PanelBrush}" Visibility="Collapsed"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0">
                <Grid Margin="12,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" x:Name="TocTitle" Text="Indice" FontSize="15" FontWeight="Bold"
                               Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,8"/>
                    <Separator Grid.Row="1" Margin="0,0,0,10"/>
                    <ListBox Grid.Row="2" x:Name="ChapterList" Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource ForegroundBrush}"
                             SelectionChanged="ChapterList_SelectionChanged"/>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>